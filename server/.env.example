# Copy to .env (gitignored) and fill in real values.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=myuser
DB_PASSWORD=
DB_DATABASE=mydb
# Remote Postgres often needs DB_SSL=true
DB_SSL=false

# Required. Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

PORT=3001
CORS_ORIGIN=http://localhost:5173

# Default admin user is created by `npm run seed` (username/password in seed script, stored in DB only).
